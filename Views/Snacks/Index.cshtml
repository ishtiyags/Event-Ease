@model List<SnackTrackMvc.Models.Snack>

<h2>Snack List</h2>

<a asp-action="Create" class="btn btn-primary">Add Snack</a>

<table class="table">
    <tr>
        <th>Name</th>
        <th>Category</th>
        <th>Price</th>
        <th></th>
    </tr>

    @foreach (var snack in Model)
    {
        <tr>
            <td>@snack.Name</td>
            <td>@snack.Category</td>
            <td>@snack.Price</td>
            <td>
                <a asp-action="Details" asp-route-id="@snack.Id">Details</a> |
                <a asp-action="Edit" asp-route-id="@snack.Id">Edit</a> |
                <a asp-action="Delete" asp-route-id="@snack.Id">Delete</a>
            </td>
        </tr>
    }
</table>